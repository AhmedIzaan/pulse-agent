# Copy to .env and fill in values before running the backend

# App
DEBUG=false

# Database (PostgreSQL on Railway)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/pulse

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Pinecone
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=pulse-articles

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=digest@pulse.ai

# CORS — comma-separated, add Vercel URL for production
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
